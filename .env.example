# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/erp_db?schema=public
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=30000
DATABASE_READ_REPLICA_URL=

# Redis Configuration (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_MAX_MEMORY=100mb

# Redis Configuration (Queue)
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_DEFAULT_JOB_ATTEMPTS=3

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# Password Hashing
BCRYPT_ROUNDS=10

# API Configuration
GRAPHQL_ENABLED=true
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_PATH=/graphql

GRPC_ENABLED=true
GRPC_URL=0.0.0.0:5000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Queue Configuration
QUEUE_DEFAULT_JOB_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_DELAY=5000
QUEUE_REMOVE_ON_COMPLETE=true
QUEUE_REMOVE_ON_FAIL=false

# Cache Configuration
CACHE_MEMORY_MAX=100
CACHE_MEMORY_TTL=300

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting (Future)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-min-32-characters
SESSION_TTL=86400

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_DATABASE_TIMEOUT=5000
HEALTH_CHECK_REDIS_TIMEOUT=3000

# Monitoring Configuration (Future)
METRICS_ENABLED=false
METRICS_PORT=9090

# Docker Configuration
DOCKER_DATABASE_HOST=postgres
DOCKER_REDIS_HOST=redis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model audit_logs {
  id             String          @id
  userId         String?
  organizationId String?
  hierarchyLevel HierarchyLevel?
  action         String
  resourceType   String
  resourceId     String?
  result         String
  metadata       Json?
  tenantId       String?
  entity         String?
  entityId       String?
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())
  organizations  organizations?  @relation(fields: [organizationId], references: [id])
  users          users?          @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
  @@index([organizationId])
  @@index([resourceType])
  @@index([tenantId])
  @@index([userId])
}

model authorization_rules {
  id              String         @id
  organizationId  String
  ruleName        String
  transactionType String
  basedOn         String
  thresholdValue  Float
  appliesToLevel  HierarchyLevel
  approverLevel   HierarchyLevel
  isActive        Boolean        @default(true)
  priority        Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  organizations   organizations  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([organizationId])
  @@index([transactionType])
}

model branches {
  id             String        @id
  organizationId String
  name           String
  code           String
  address        String?
  managerId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  organizations  organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments    departments[]
  users          users[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model departments {
  id             String        @id
  organizationId String
  branchId       String?
  name           String
  code           String
  managerId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  branches       branches?     @relation(fields: [branchId], references: [id])
  organizations  organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          users[]

  @@unique([organizationId, code])
  @@index([branchId])
  @@index([organizationId])
}

model organizations {
  id                                        String                @id
  name                                      String                @unique
  type                                      OrganizationType
  status                                    OrganizationStatus    @default(ACTIVE)
  settings                                  Json?
  ownerId                                   String?               @unique
  createdAt                                 DateTime              @default(now())
  updatedAt                                 DateTime
  audit_logs                                audit_logs[]
  authorization_rules                       authorization_rules[]
  branches                                  branches[]
  departments                               departments[]
  users_organizations_ownerIdTousers        users?                @relation("organizations_ownerIdTousers", fields: [ownerId], references: [id])
  permission_matrices                       permission_matrices[]
  users_users_organizationIdToorganizations users[]               @relation("users_organizationIdToorganizations")

  @@index([status])
}

model permission_matrices {
  id                                           String        @id
  userId                                       String
  organizationId                               String
  module                                       String
  actions                                      String[]
  grantedById                                  String
  grantedAt                                    DateTime      @default(now())
  revokedAt                                    DateTime?
  users_permission_matrices_grantedByIdTousers users         @relation("permission_matrices_grantedByIdTousers", fields: [grantedById], references: [id])
  organizations                                organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users_permission_matrices_userIdTousers      users         @relation("permission_matrices_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([grantedById])
  @@index([organizationId])
  @@index([revokedAt])
  @@index([userId])
}

model permission_snapshots {
  id              String   @id
  userId          String
  snapshotData    Json
  fingerprintHash String
  reason          String
  createdAt       DateTime @default(now())
  users           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model permissions {
  id               String             @id
  name             String             @unique
  resource         String
  action           String
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  createdBy        String?
  updatedBy        String?
  role_permissions role_permissions[]

  @@unique([resource, action])
  @@index([action])
  @@index([resource])
}

model role_permissions {
  roleId       String
  permissionId String
  grantedAt    DateTime    @default(now())
  grantedBy    String?
  permissions  permissions @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  roles        roles       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([roleId])
}

model roles {
  id               String             @id
  name             String             @unique
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  createdBy        String?
  updatedBy        String?
  role_permissions role_permissions[]
  user_roles       user_roles[]

  @@index([name])
}

model sessions {
  id                     String    @id
  userId                 String
  refreshTokenHash       String    @unique
  accessTokenFingerprint String
  ipAddress              String?
  userAgent              String?
  expiresAt              DateTime
  revokedAt              DateTime?
  createdAt              DateTime  @default(now())
  users                  users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId])
}

model staff_profiles {
  id               String           @id
  userId           String           @unique
  fullName         String
  positionTitle    String?
  employeeCode     String?
  reportsToUserId  String?
  employmentStatus EmploymentStatus @default(ACTIVE)
  hireDate         DateTime?
  terminationDate  DateTime?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  users            users            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportsToUserId])
  @@index([userId])
}

model system_config {
  id          String    @id
  key         String    @unique
  value       Json
  description String?
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?

  @@index([isPublic])
  @@index([key])
}

model tenants {
  id        String    @id
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([isActive])
  @@index([slug])
}

model user_roles {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  roles      roles    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
}

model users {
  id                                                         String                 @id
  email                                                      String
  passwordHash                                               String?
  pinHash                                                    String?
  googleId                                                   String?                @unique
  organizationId                                             String
  hierarchyLevel                                             HierarchyLevel
  status                                                     UserStatus             @default(ACTIVE)
  createdById                                                String?
  branchId                                                   String?
  departmentId                                               String?
  lastLoginAt                                                DateTime?
  failedLoginAttempts                                        Int                    @default(0)
  lockedUntil                                                DateTime?
  firstName                                                  String?
  lastName                                                   String?
  isActive                                                   Boolean                @default(true)
  tenantId                                                   String?
  createdAt                                                  DateTime               @default(now())
  updatedAt                                                  DateTime
  deletedAt                                                  DateTime?
  createdBy_legacy                                           String?
  updatedBy                                                  String?
  audit_logs                                                 audit_logs[]
  organizations_organizations_ownerIdTousers                 organizations?         @relation("organizations_ownerIdTousers")
  permission_matrices_permission_matrices_grantedByIdTousers permission_matrices[]  @relation("permission_matrices_grantedByIdTousers")
  permission_matrices_permission_matrices_userIdTousers      permission_matrices[]  @relation("permission_matrices_userIdTousers")
  permission_snapshots                                       permission_snapshots[]
  sessions                                                   sessions[]
  staff_profiles                                             staff_profiles?
  user_roles                                                 user_roles[]
  branches                                                   branches?              @relation(fields: [branchId], references: [id])
  users                                                      users?                 @relation("usersTousers", fields: [createdById], references: [id])
  other_users                                                users[]                @relation("usersTousers")
  departments                                                departments?           @relation(fields: [departmentId], references: [id])
  organizations_users_organizationIdToorganizations          organizations          @relation("users_organizationIdToorganizations", fields: [organizationId], references: [id])

  @@unique([email, organizationId])
  @@index([branchId])
  @@index([createdById])
  @@index([departmentId])
  @@index([email])
  @@index([hierarchyLevel])
  @@index([isActive])
  @@index([organizationId])
  @@index([status])
  @@index([tenantId])
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum HierarchyLevel {
  OWNER
  MANAGER
  WORKER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum OrganizationType {
  ENTERPRISE
  SME
  STARTUP
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}
